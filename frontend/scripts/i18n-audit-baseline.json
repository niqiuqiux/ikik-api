    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"公众号 AppSecret\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"仅在微信内浏览器可用；非微信环境下会显示不可用。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"开通引导：Google Cloud Console → APIs & Services → OAuth consent screen 完成同意屏幕；Credentials → Create Credentials → OAuth client ID，类型选择 Web application，并把下面地址加入 Auth",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"控制登录页是否要求用户先阅读并同意服务条款、隐私政策或其他 Markdown 文档。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"浏览器回调地址\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"配置邮箱型第三方 OAuth 登录入口，用户可通过 GitHub 或 Google 完成登录与注册。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"如果同时启用 PC 应用和公众号/移动应用，这些应用需要挂在同一个微信开放平台主体下，否则 UnionID 无法稳定归并账号。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"文档名称可自定义，内容按 Markdown 保存。可参考：服务条款、使用政策、支持的国家和地区、服务特定条款。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"用于 PC 应用和公众号的网页回调。移动应用走原生 SDK 时不直接使用这个浏览器回调。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"原生移动端通过微信 SDK 唤起授权，网页端不会直接发起该流程。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"桌面浏览器通过微信开放平台扫码登录。可与公众号或移动应用同时存在。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"GitHub OAuth App 需要 read:user user:email 权限，回调地址填写下方后端地址。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "\"Google OAuth 客户端需要 openid email profile 范围，并在凭据里登记后端回调地址。\",",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "→ New OAuth App；Homepage URL 填站点域名，Authorization callback URL 填下面的后端回调地址。",
      "count": 1
    },
    {
      "file": "src/views/admin/SettingsView.vue",
      "text": "开通引导：GitHub Settings → Developer settings →",
      "count": 1
    },
