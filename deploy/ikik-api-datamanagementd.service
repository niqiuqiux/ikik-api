[Unit]
Description=ikik-api Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=ikik-api
Group=ikik-api
WorkingDirectory=/opt/ikik-api
ExecStart=/opt/ikik-api/datamanagementd \
  -socket-path /tmp/ikik-api-datamanagement.sock \
  -sqlite-path /var/lib/ikik-api/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
