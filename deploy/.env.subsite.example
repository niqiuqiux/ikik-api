# ikik-api subsite-agent deployment environment.
# Copy this file to .env.subsite on the subsite server.

# Public bind address for the Docker port mapping.
SUBSITE_BIND_HOST=0.0.0.0
SUBSITE_PORT=8081
SUBSITE_UID=1000
SUBSITE_GID=1000

# Values from the master admin Subsites page.
SUBSITE_ID=
SUBSITE_PUBLIC_URL=https://edge.example.com
SUBSITE_MASTER_URL=https://master.example.com
SUBSITE_MASTER_SECRET=

# Optional version label reported in heartbeat.
SUBSITE_VERSION=local
